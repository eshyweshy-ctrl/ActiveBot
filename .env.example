# ACTIVEBOT - Environment Variables Template
# Copy this file to .env and fill in your values

# ======================
# REQUIRED - Trading Keys
# ======================
# Your CFGI.io API key
CFGI_API_KEY=your_cfgi_api_key_here

# Your Polymarket wallet private key (KEEP SECRET!)
# WARNING: Rotate this key if it was ever exposed publicly
POLYMARKET_PRIVATE_KEY=your_polymarket_private_key_here

# ======================
# REQUIRED - Telegram
# ======================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ======================
# OPTIONAL - Configuration
# ======================
# Polygon RPC URL (default works fine)
RPC_URL=https://polygon-rpc.com

# Default trade size in USDC
TRADE_SIZE_USDC=1

# Backend URL for frontend (update with your domain/IP)
# For local: http://localhost:8001
# For production: https://your-domain.com or http://your-droplet-ip:8001
REACT_APP_BACKEND_URL=http://localhost:8001
